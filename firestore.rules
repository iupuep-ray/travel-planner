rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasOnlyKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function memberBelongsToCurrentUser() {
      return isSignedIn() && resource.data.authUid == request.auth.uid;
    }

    match /members/{memberId} {
      allow read: if isSignedIn();

      // Registration flow creates the user's own member profile.
      allow create: if isSignedIn()
        && request.resource.data.authUid == request.auth.uid
        && hasOnlyKeys([
          'name',
          'email',
          'avatar',
          'authUid',
          'createdAt',
          'updatedAt'
        ]);

      allow update: if memberBelongsToCurrentUser()
        && request.resource.data.authUid == resource.data.authUid
        && request.resource.data.createdAt == resource.data.createdAt
        && hasOnlyKeys([
          'name',
          'email',
          'avatar',
          'authUid',
          'createdAt',
          'updatedAt'
        ]);

      allow delete: if memberBelongsToCurrentUser();
    }

    // Current schema is a shared trip board. Without trip/member scoping,
    // the strongest safe baseline is "authenticated users only".
    match /schedules/{documentId} {
      allow read, write: if isSignedIn();
    }

    match /planning/{documentId} {
      allow read, write: if isSignedIn();
    }

    match /expenses/{documentId} {
      allow read, write: if isSignedIn();
    }

    match /settlements/{documentId} {
      allow read, write: if isSignedIn();
    }

    match /pushTokens/{tokenId} {
      allow read: if isSignedIn() && resource.data.authUid == request.auth.uid;

      allow create, update: if isSignedIn()
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.token == tokenId
        && hasOnlyKeys([
          'authUid',
          'token',
          'updatedAt',
          'userAgent'
        ]);

      allow delete: if isSignedIn() && resource.data.authUid == request.auth.uid;
    }

    // Cloud Functions manages delivery deduplication logs.
    match /todoReminderDeliveries/{documentId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
